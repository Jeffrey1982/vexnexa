generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                     String                  @id @default(cuid())
  email                  String                  @unique
  firstName              String?
  lastName               String?
  company                String?
  jobTitle               String?
  phoneNumber            String?
  website                String?
  country                String?
  marketingEmails        Boolean                 @default(false)
  productUpdates         Boolean                 @default(true)
  teamInvitations        Boolean                 @default(true)
  scanNotifications      Boolean                 @default(true)
  weeklyReports          Boolean                 @default(false)
  reportEmailEnabled     Boolean                 @default(false)
  reportEmailFrequency   String                  @default("monthly")
  reportRecipientEmail   String?
  reportFormat           String                  @default("pdf")
  nextReportAt           DateTime?
  lastReportSentAt       DateTime?
  profileCompleted       Boolean                 @default(false)
  plan                   Plan                    @default(FREE)
  subscriptionStatus     String                  @default("active")
  trialEndsAt            DateTime?
  trialStartsAt          DateTime?
  trialOrigin            String?
  mollieCustomerId       String?                 @unique
  mollieSubscriptionId   String?
  billingInterval        String                  @default("monthly")
  hasAssurance           Boolean                 @default(false)
  extraWebsiteCount      Int                     @default(0)
  extraSeats             Int                     @default(0)
  isAdmin                Boolean                 @default(false)
  deletedAt              DateTime?
  deletedBy              String?
  lastLoginAt            DateTime?
  lastFailedPaymentAt    DateTime?
  lastFailedPaymentReason String?
  auditCredits           Int                     @default(0) @map("audit_credits")
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  addOns                 AddOn[]
  adminNotes             AdminUserNote[]         @relation("AdminNotes")
  assuranceSubscriptions AssuranceSubscription[] @relation("AssuranceSubscriptions")
  auditAttachments       AuditAttachment[]
  testedAuditItems       AuditItem[]
  auditTemplates         AuditTemplate[]
  billingProfile         BillingProfile?
  blogPosts              BlogPost[]
  checkoutQuotes         CheckoutQuote[]
  assignedByIssues       Issue[]                 @relation("AssignedBy")
  assignedIssues         Issue[]                 @relation("AssignedTo")
  createdIssues          Issue[]                 @relation("CreatedBy")
  resolvedIssues         Issue[]                 @relation("ResolvedBy")
  issueActivities        IssueActivity[]
  issueComments          IssueComment[]
  assignedAudits         ManualAudit[]           @relation("AuditAssignee")
  createdAudits          ManualAudit[]           @relation("AuditCreator")
  reviewedAudits         ManualAudit[]           @relation("AuditReviewer")
  notifications          Notification[]
  portfolios             Portfolio[]
  scanSchedules          ScanSchedule[]          @relation("UserScanSchedules")
  scheduledScans         ScheduledScan[]
  sites                  Site[]
  supportTickets         SupportTicket[]
  supportTicketMessages  SupportTicketMessage[]
  ownedTeams             Team[]                  @relation("TeamOwner")
  sentInvites            TeamInvite[]            @relation("InvitedBy")
  invitedBy              TeamMember[]            @relation("InvitedByUser")
  teamMemberships        TeamMember[]
  usages                 Usage[]
  webhookEndpoints       WebhookEndpoint[]
  whiteLabel             WhiteLabel?

  @@index([deletedAt])
}

model Site {
  id             String          @id @default(cuid())
  userId         String
  url            String
  portfolioId    String?
  deletedAt      DateTime?
  createdAt      DateTime        @default(now())
  crawls         Crawl[]
  manualAudits   ManualAudit[]
  pages          Page[]
  scans          Scan[]
  scanSchedules  ScanSchedule[]  @relation("SiteScanSchedules")
  scheduledScans ScheduledScan[]
  portfolio      Portfolio?      @relation(fields: [portfolioId], references: [id])
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  teams          Team[]          @relation("TeamSites")

  @@unique([userId, url])
  @@index([userId])
  @@index([portfolioId])
  @@index([deletedAt])
}

model Page {
  id           String   @id @default(cuid())
  siteId       String
  url          String
  title        String?
  latestScanId String?
  createdAt    DateTime @default(now())
  site         Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  scans        Scan[]

  @@unique([siteId, url])
  @@index([siteId])
}

model Scan {
  id                     String          @id @default(cuid())
  siteId                 String
  pageId                 String?
  status                 ScanStatus      @default(PENDING)
  score                  Int?
  issues                 Int?
  reportUrl              String?
  impactCritical         Int             @default(0)
  impactSerious          Int             @default(0)
  impactModerate         Int             @default(0)
  impactMinor            Int             @default(0)
  previousScanId         String?
  scoreImprovement       Int?
  issuesFixed            Int             @default(0)
  newIssues              Int             @default(0)
  wcagAACompliance       Float?
  wcagAAACompliance      Float?
  violationsByRule       Json?
  performanceScore       Float?
  firstContentfulPaint   Float?
  largestContentfulPaint Float?
  cumulativeLayoutShift  Float?
  firstInputDelay        Float?
  totalBlockingTime      Float?
  seoScore               Float?
  metaDescription        String?
  headingStructure       Json?
  altTextCoverage        Float?
  linkAccessibility      Float?
  adaRiskLevel           String?
  wcag21Compliance       Float?
  wcag22Compliance       Float?
  complianceGaps         Json?
  legalRiskScore         Float?
  scanDuration           Int?
  pageLoadTime           Int?
  elementsScanned        Int?
  pageWeightBytes        Int?
  domNodeCount           Int?
  qualityWarnings        Json?
  resultJson             Json?
  raw                    Json?
  deletedAt              DateTime?
  createdAt              DateTime        @default(now())
  assuranceScans         AssuranceScan[]
  scanIssues             Issue[]
  manualAudits           ManualAudit[]
  page                   Page?           @relation(fields: [pageId], references: [id])
  previousScan           Scan?           @relation("ScanHistory", fields: [previousScanId], references: [id])
  nextScans              Scan[]          @relation("ScanHistory")
  site                   Site            @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
  @@index([pageId])
  @@index([createdAt])
  @@index([siteId, createdAt])
  @@index([deletedAt])
}

enum ScanStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model Usage {
  id        String   @id @default(cuid())
  userId    String
  period    String
  pages     Int      @default(0)
  sites     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period])
}

model Crawl {
  id          String     @id @default(cuid())
  siteId      String
  status      String     @default("queued")
  maxPages    Int        @default(50)
  maxDepth    Int        @default(3)
  pagesQueued Int        @default(0)
  pagesDone   Int        @default(0)
  pagesError  Int        @default(0)
  startedAt   DateTime   @default(now())
  finishedAt  DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  site        Site       @relation(fields: [siteId], references: [id], onDelete: Cascade)
  crawlUrls   CrawlUrl[]

  @@index([siteId])
  @@index([status])
}

model CrawlUrl {
  id          String    @id @default(cuid())
  crawlId     String
  url         String
  depth       Int       @default(0)
  status      String    @default("queued")
  reason      String?
  createdAt   DateTime  @default(now())
  processedAt DateTime?
  crawl       Crawl     @relation(fields: [crawlId], references: [id], onDelete: Cascade)

  @@unique([crawlId, url])
  @@index([crawlId, status])
}

model Benchmark {
  id          String   @id @default(cuid())
  industry    String
  category    String?
  avgScore    Float
  avgCritical Float
  avgSerious  Float
  avgModerate Float
  avgMinor    Float
  avgWcagAA   Float
  avgWcagAAA  Float
  sampleSize  Int
  lastUpdated DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([industry, category])
  @@index([industry])
}

model WhiteLabel {
  id             String   @id @default(cuid())
  userId         String   @unique
  companyName    String?
  logoUrl        String?
  faviconUrl     String?
  primaryColor   String   @default("#3B82F6")
  secondaryColor String   @default("#1F2937")
  accentColor    String   @default("#10B981")
  supportEmail   String?
  website        String?
  phone          String?
  footerText     String?
  showPoweredBy  Boolean  @default(true)
  customDomain   String?
  subdomain      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Portfolio {
  id                     String   @id @default(cuid())
  userId                 String
  name                   String
  description            String?
  totalSites             Int      @default(0)
  avgScore               Float?
  totalIssues            Int      @default(0)
  riskScore              Float?
  avgPerformance         Float?
  performanceCorrelation Float?
  priorityMatrix         Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sites                  Site[]

  @@index([userId])
}

model Team {
  id          String       @id @default(cuid())
  name        String
  description String?
  ownerId     String
  deletedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  owner       User         @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  invites     TeamInvite[]
  members     TeamMember[]
  sites       Site[]       @relation("TeamSites")

  @@index([ownerId])
  @@index([deletedAt])
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  role      TeamRole @default(VIEWER)
  invitedBy String?
  joinedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  inviter   User?    @relation("InvitedByUser", fields: [invitedBy], references: [id])
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

model TeamInvite {
  id         String    @id @default(cuid())
  teamId     String
  email      String
  role       TeamRole  @default(VIEWER)
  invitedBy  String
  token      String    @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())
  inviter    User      @relation("InvitedBy", fields: [invitedBy], references: [id], onDelete: Cascade)
  team       Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([email])
}

model Issue {
  id             String          @id @default(cuid())
  scanId         String
  violationId    String
  title          String
  description    String?
  status         IssueStatus     @default(OPEN)
  priority       IssuePriority   @default(MEDIUM)
  assignedToId   String?
  assignedById   String?
  createdById    String
  resolvedAt     DateTime?
  resolvedById   String?
  dueDate        DateTime?
  estimatedHours Int?
  actualHours    Int?
  tags           String[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  assignedBy     User?           @relation("AssignedBy", fields: [assignedById], references: [id])
  assignedTo     User?           @relation("AssignedTo", fields: [assignedToId], references: [id])
  createdBy      User            @relation("CreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  resolvedBy     User?           @relation("ResolvedBy", fields: [resolvedById], references: [id])
  scan           Scan            @relation(fields: [scanId], references: [id], onDelete: Cascade)
  activities     IssueActivity[]
  comments       IssueComment[]

  @@unique([scanId, violationId])
  @@index([scanId])
  @@index([assignedToId])
  @@index([createdById])
  @@index([status])
  @@index([priority])
}

model IssueComment {
  id        String   @id @default(cuid())
  issueId   String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([issueId])
  @@index([userId])
}

model IssueActivity {
  id        String   @id @default(cuid())
  issueId   String
  userId    String
  action    String
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([issueId])
  @@index([userId])
}

model ManualAudit {
  id                String            @id @default(cuid())
  siteId            String
  scanId            String?
  name              String
  description       String?
  templateId        String?
  status            String            @default("draft")
  createdById       String
  assignedToId      String?
  reviewedById      String?
  totalCriteria     Int               @default(0)
  completedCriteria Int               @default(0)
  passedCriteria    Int               @default(0)
  failedCriteria    Int               @default(0)
  overallScore      Float?
  wcagLevel         String?
  compliant         Boolean           @default(false)
  dueDate           DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  reviewedAt        DateTime?
  deletedAt         DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  attachments       AuditAttachment[]
  items             AuditItem[]
  assignedTo        User?             @relation("AuditAssignee", fields: [assignedToId], references: [id])
  createdBy         User              @relation("AuditCreator", fields: [createdById], references: [id], onDelete: Cascade)
  reviewedBy        User?             @relation("AuditReviewer", fields: [reviewedById], references: [id])
  scan              Scan?             @relation(fields: [scanId], references: [id])
  site              Site              @relation(fields: [siteId], references: [id], onDelete: Cascade)
  template          AuditTemplate?    @relation(fields: [templateId], references: [id])

  @@index([siteId])
  @@index([scanId])
  @@index([createdById])
  @@index([assignedToId])
  @@index([status])
  @@index([deletedAt])
}

model AuditTemplate {
  id          String           @id @default(cuid())
  name        String
  description String?
  category    String
  wcagLevel   String?
  isPublic    Boolean          @default(true)
  isDefault   Boolean          @default(false)
  createdById String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  criteria    AuditCriterion[]
  createdBy   User?            @relation(fields: [createdById], references: [id])
  audits      ManualAudit[]

  @@index([category])
  @@index([createdById])
}

model AuditCriterion {
  id            String        @id @default(cuid())
  templateId    String
  category      String
  subcategory   String?
  title         String
  description   String?
  howToTest     String?
  wcagCriterion String?
  wcagLevel     String?
  wcagUrl       String?
  priority      String        @default("medium")
  required      Boolean       @default(true)
  order         Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  template      AuditTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([category])
}

model AuditItem {
  id               String      @id @default(cuid())
  auditId          String
  criterionId      String?
  category         String
  subcategory      String?
  title            String
  description      String?
  howToTest        String?
  wcagCriterion    String?
  wcagLevel        String?
  wcagUrl          String?
  status           String      @default("pending")
  result           String?
  notes            String?
  screenshotUrls   String[]
  elementSelector  String?
  pageUrl          String?
  testedById       String?
  testedAt         DateTime?
  remediationNotes String?
  priority         String      @default("medium")
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  audit            ManualAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)
  testedBy         User?       @relation(fields: [testedById], references: [id])

  @@index([auditId])
  @@index([testedById])
  @@index([status])
  @@index([category])
}

model AuditAttachment {
  id           String      @id @default(cuid())
  auditId      String
  fileName     String
  fileUrl      String
  fileType     String
  fileSize     Int?
  description  String?
  uploadedById String
  createdAt    DateTime    @default(now())
  audit        ManualAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)
  uploadedBy   User        @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([auditId])
  @@index([uploadedById])
}

model BlogPost {
  id              String    @id @default(cuid())
  title           String
  slug            String
  content         String
  excerpt         String?
  coverImage      String?
  locale          String    @default("en")
  metaTitle       String?
  metaDescription String?
  metaKeywords    String[]
  category        String
  tags            String[]
  status          String    @default("draft")
  publishedAt     DateTime?
  authorId        String
  authorName      String?
  views           Int       @default(0)
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  author          User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([slug, locale])
  @@index([authorId])
  @@index([slug])
  @@index([deletedAt])
  @@index([status])
  @@index([category])
  @@index([publishedAt])
  @@index([locale])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  reason    String?
  source    String?
  status    String   @default("new")
  replied   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

enum PartnerApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

/// Pilot Partner Program applications (marketing funnel; stored via server action).
model PartnerApplication {
  id          String                   @id @default(cuid())
  fullName    String
  companyName String
  email       String
  phone       String?
  website     String
  clientSites String
  services    Json
  motivation  String
  status      PartnerApplicationStatus @default(PENDING)
  createdAt   DateTime                 @default(now())

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@map("partner_applications")
}

model SupportTicket {
  id        String                 @id @default(cuid())
  userId    String
  subject   String
  category  TicketCategory         @default(GENERAL)
  priority  TicketPriority         @default(MEDIUM)
  status    TicketStatus           @default(OPEN)
  deletedAt DateTime?
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  SupportTicketMessage[]

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([category])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([deletedAt])
}

model SupportTicketMessage {
  id           String            @id @default(cuid())
  ticketId     String
  senderType   MessageSenderType
  senderUserId String?
  message      String
  createdAt    DateTime          @default(now())
  senderUser   User?             @relation(fields: [senderUserId], references: [id])
  ticket       SupportTicket     @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([senderUserId])
  @@index([createdAt])
}

model AdminUserNote {
  id        String   @id @default(cuid())
  userId    String
  adminId   String?
  note      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  admin     User?    @relation("AdminNotes", fields: [adminId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([adminId])
  @@index([createdAt])
}

model UserAdminEvent {
  id          String         @id @default(cuid())
  userId      String
  adminId     String?
  eventType   AdminEventType
  metadata    Json?
  description String?
  createdAt   DateTime       @default(now())

  @@index([userId])
  @@index([adminId])
  @@index([eventType])
  @@index([createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  link      String?
  read      Boolean          @default(false)
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
  @@index([createdAt])
}

model WebhookEndpoint {
  id            String         @id @default(cuid())
  userId        String
  name          String
  url           String
  secret        String
  events        WebhookEvent[]
  active        Boolean        @default(true)
  lastTriggered DateTime?
  successCount  Int            @default(0)
  failureCount  Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([active])
}

model ErrorLog {
  id         String    @id @default(cuid())
  message    String
  stack      String?
  level      String    @default("error")
  source     String?
  statusCode Int?
  userId     String?
  userEmail  String?
  url        String?
  method     String?
  userAgent  String?
  ip         String?
  metadata   Json?
  resolved   Boolean   @default(false)
  resolvedBy String?
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([createdAt])
  @@index([level])
  @@index([resolved])
  @@index([userId])
}

model ApiLog {
  id           String   @id @default(cuid())
  method       String
  path         String
  statusCode   Int
  duration     Int
  userId       String?
  userEmail    String?
  ip           String?
  userAgent    String?
  requestBody  Json?
  responseBody Json?
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([path])
  @@index([statusCode])
  @@index([userId])
  @@index([method])
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  entity      String
  entityId    String?
  description String
  actorId     String?
  actorEmail  String?
  actorType   String   @default("user")
  ip          String?
  userAgent   String?
  metadata    Json?
  oldValues   Json?
  newValues   Json?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([action])
  @@index([actorId])
  @@index([entity])
  @@index([entityId])
}

model ScheduledScan {
  id              String    @id @default(cuid())
  userId          String
  siteId          String
  frequency       String
  dayOfWeek       Int?
  dayOfMonth      Int?
  timeOfDay       String    @default("00:00")
  active          Boolean   @default(true)
  lastRunAt       DateTime?
  nextRunAt       DateTime?
  emailOnComplete Boolean   @default(true)
  emailOnIssues   Boolean   @default(true)
  webhookUrl      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  site            Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([siteId])
  @@index([active, nextRunAt])
  @@index([nextRunAt])
}

model AddOn {
  id                   String    @id @default(cuid())
  userId               String
  type                 AddOnType
  mollieSubscriptionId String?   @unique
  status               String    @default("active")
  quantity             Int       @default(1)
  pricePerUnit         Decimal   @db.Decimal(10, 2)
  totalPrice           Decimal   @db.Decimal(10, 2)
  activatedAt          DateTime  @default(now())
  canceledAt           DateTime?
  expiresAt            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
  @@index([type])
  @@index([status])
}

model MollieProduct {
  id              String   @id @default(cuid())
  productType     String
  productKey      String
  interval        String
  mollieProductId String?
  molliePriceId   String?
  amount          Decimal  @db.Decimal(10, 2)
  currency        String   @default("EUR")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([productKey, interval])
  @@index([productType])
  @@index([active])
  @@index([productKey, interval, active])
}

/// Idempotency log for inbound payment-provider webhooks (Mollie payment / subscription).
/// `webhookId` is the provider id (e.g. Mollie payment id `tr_xxx` or subscription id `sub_xxx`).
/// `webhookType` distinguishes "payment" vs. "subscription" vs. "addon" etc.
/// Status values: "received" | "processed" | "failed".
model ProcessedWebhook {
  id          String   @id @default(cuid())
  webhookId   String
  webhookType String
  status      String   @default("received")
  errorMessage String?
  attempts    Int      @default(1)
  metadata    Json?
  processedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([webhookId, webhookType])
  @@index([status])
  @@index([createdAt])
}

model BillingProfile {
  id                 String    @id @default(cuid())
  userId             String    @unique
  billingType        String    @default("individual")
  fullName           String?
  companyName        String?
  countryCode        String    @default("NL")
  vatId              String?
  vatValid           Boolean   @default(false)
  vatCheckedAt       DateTime?
  kvkNumber          String?
  registrationNumber String?
  taxId              String?
  addressLine1       String?
  addressCity        String?
  addressPostal      String?
  addressRegion      String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([vatId])
  @@index([countryCode])
}

model CheckoutQuote {
  id              String    @id @default(cuid())
  userId          String
  product         String
  plan            String?
  billingCycle    String?
  baseAmount      Decimal   @db.Decimal(10, 2)
  vatAmount       Decimal   @db.Decimal(10, 2)
  totalAmount     Decimal   @db.Decimal(10, 2)
  currency        String    @default("EUR")
  taxRatePercent  Decimal   @db.Decimal(5, 2)
  taxMode         String
  taxNotes        String?
  customerType    String
  customerCountry String
  companyName     String?
  vatId           String?
  vatIdValid      Boolean   @default(false)
  molliePaymentId String?
  invoiceNumber   String?   @unique
  invoiceSentAt   DateTime?
  createdAt       DateTime  @default(now())
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([molliePaymentId])
  @@index([createdAt])
}

model AssuranceSubscription {
  id                   String            @id @default(cuid())
  userId               String
  tier                 AssuranceTier     @default(BASIC)
  status               String            @default("active")
  mollieSubscriptionId String?           @unique
  billingCycle         String            @default("monthly")
  pricePerMonth        Decimal           @db.Decimal(10, 2)
  totalPrice           Decimal           @db.Decimal(10, 2)
  vatRate              Decimal?          @db.Decimal(5, 4)
  taxRegime            String?
  countryCode          String?
  vatId                String?
  activatedAt          DateTime          @default(now())
  canceledAt           DateTime?
  expiresAt            DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  domains              AssuranceDomain[]
  user                 User              @relation("AssuranceSubscriptions", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
  @@index([tier])
}

model AssuranceDomain {
  id              String                @id @default(cuid())
  subscriptionId  String
  domain          String
  label           String?
  scanFrequency   AssuranceFrequency    @default(WEEKLY)
  scoreThreshold  Int                   @default(90)
  active          Boolean               @default(true)
  language        String                @default("en")
  emailRecipients String[]
  dayOfWeek       Int                   @default(1)
  timeOfDay       String                @default("09:00")
  lastRunAt       DateTime?
  nextRunAt       DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  alerts          AssuranceAlert[]
  subscription    AssuranceSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  reports         AssuranceReport[]
  scans           AssuranceScan[]

  @@unique([subscriptionId, domain])
  @@index([subscriptionId])
  @@index([active, nextRunAt])
  @@index([nextRunAt])
}

model AssuranceScan {
  id                String          @id @default(cuid())
  domainId          String
  scanId            String
  score             Int
  wcagAACompliance  Float?
  wcagAAACompliance Float?
  issuesCount       Int
  impactCritical    Int
  impactSerious     Int
  impactModerate    Int
  impactMinor       Int
  previousScanId    String?
  scoreChange       Int?            @default(0)
  isRegression      Boolean         @default(false)
  createdAt         DateTime        @default(now())
  domain            AssuranceDomain @relation(fields: [domainId], references: [id], onDelete: Cascade)
  previousScan      AssuranceScan?  @relation("ScanHistory", fields: [previousScanId], references: [id])
  nextScans         AssuranceScan[] @relation("ScanHistory")
  scan              Scan            @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([domainId])
  @@index([domainId, createdAt])
  @@index([scanId])
  @@index([isRegression])
}

model AssuranceReport {
  id                String          @id @default(cuid())
  domainId          String
  scanId            String
  pdfUrl            String
  language          String
  score             Int
  threshold         Int
  trendData         Json
  wcagAACompliance  Float?
  wcagAAACompliance Float?
  emailSentTo       String[]
  sentAt            DateTime?
  createdAt         DateTime        @default(now())
  domain            AssuranceDomain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@index([domainId])
  @@index([domainId, createdAt])
  @@index([scanId])
}

model AssuranceAlert {
  id            String                 @id @default(cuid())
  domainId      String
  type          AssuranceAlertType
  severity      AssuranceAlertSeverity @default(MEDIUM)
  title         String
  message       String
  currentScore  Int
  threshold     Int?
  previousScore Int?
  scanId        String?
  emailSentTo   String[]
  sentAt        DateTime?
  resolved      Boolean                @default(false)
  resolvedAt    DateTime?
  resolvedBy    String?
  createdAt     DateTime               @default(now())
  domain        AssuranceDomain        @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@index([domainId])
  @@index([domainId, createdAt])
  @@index([resolved])
  @@index([type])
}

model Coupon {
  id             String             @id @default(cuid())
  code           String             @unique
  name           String?
  description    String?
  grantType      CouponGrantType
  grantValue     String
  maxRedemptions Int?
  redeemedCount  Int                @default(0)
  perUserLimit   Int                @default(1)
  startsAt       DateTime?
  expiresAt      DateTime?
  isActive       Boolean            @default(true)
  createdBy      String
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  redemptions    CouponRedemption[]

  @@index([code])
  @@index([isActive])
  @@index([createdBy])
  @@index([expiresAt])
}

model CouponRedemption {
  id         String   @id @default(cuid())
  couponId   String
  userId     String
  metadata   Json?
  redeemedAt DateTime @default(now())
  coupon     Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@unique([couponId, userId])
  @@index([couponId])
  @@index([userId])
  @@index([redeemedAt])
}

model ScanSchedule {
  id                          String            @id @default(cuid())
  userId                      String
  siteId                      String
  isEnabled                   Boolean           @default(true)
  timezone                    String            @default("Europe/Amsterdam")
  frequency                   ScheduleFrequency @default(WEEKLY)
  daysOfWeek                  Int[]
  dayOfMonth                  Int?
  timeOfDay                   String            @default("09:00")
  startsAt                    DateTime          @default(now())
  endsAt                      DateTime?
  lastRunAt                   DateTime?
  nextRunAt                   DateTime
  recipients                  String[]
  deliverFormat               DeliverFormat     @default(PDF)
  includeExecutiveSummaryOnly Boolean           @default(false)
  consecutiveFailures         Int               @default(0)
  createdAt                   DateTime          @default(now())
  updatedAt                   DateTime          @updatedAt
  site                        Site              @relation("SiteScanSchedules", fields: [siteId], references: [id], onDelete: Cascade)
  user                        User              @relation("UserScanSchedules", fields: [userId], references: [id], onDelete: Cascade)
  runs                        ScheduleRun[]

  @@index([userId])
  @@index([siteId])
  @@index([isEnabled, nextRunAt])
  @@index([nextRunAt])
}

model ScheduleRun {
  id          String       @id @default(cuid())
  scheduleId  String
  windowKey   String
  status      String
  error       String?
  scanScore   Int?
  emailSentAt DateTime?
  emailId     String?
  startedAt   DateTime     @default(now())
  completedAt DateTime?
  schedule    ScanSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, windowKey])
  @@index([scheduleId])
  @@index([status])
}

