{
  "colors": {
    "primary": {
      "DEFAULT": "#0d9488",
      "foreground": "#ffffff",
      "50": "#f0fdfa",
      "100": "#ccfbf1",
      "200": "#99f6e4",
      "300": "#5eead4",
      "400": "#2dd4bf",
      "500": "#14b8a6",
      "600": "#0d9488",
      "700": "#0f766e",
      "800": "#115e59",
      "900": "#134e4a"
    },
    "coral": {
      "DEFAULT": "#FFB3D9",
      "50": "#FFF5FB",
      "100": "#FFEAF6",
      "200": "#FFD6ED",
      "300": "#FFC2E4",
      "400": "#FFADDB",
      "500": "#FFB3D9",
      "600": "#FF8DC7",
      "700": "#FF6BB5",
      "800": "#E54A95",
      "900": "#C93D7F"
    },
    "cyan": {
      "DEFAULT": "#A8E6CF",
      "50": "#F0FCF7",
      "100": "#E0F9F0",
      "200": "#C7F3E3",
      "300": "#ADECD6",
      "400": "#A8E6CF",
      "500": "#8DE0C1",
      "600": "#6DD4B0",
      "700": "#4DC89E",
      "800": "#3BA982",
      "900": "#2F8A6B"
    },
    "sunny": {
      "DEFAULT": "#0f172a",
      "50": "#f8fafc",
      "100": "#f1f5f9",
      "200": "#e2e8f0",
      "300": "#cbd5e1",
      "400": "#94a3b8",
      "500": "#64748b",
      "600": "#475569",
      "700": "#334155",
      "800": "#1e293b",
      "900": "#0f172a"
    }
  },
  "typography": {
    "fontFamily": {
      "display": ["Space Grotesk", "system-ui", "sans-serif"],
      "body": ["Inter", "system-ui", "sans-serif"]
    },
    "fontSize": {
      "display-xl": {
        "size": "4.5rem",
        "lineHeight": "1.1",
        "letterSpacing": "-0.02em",
        "fontWeight": "700"
      },
      "display-lg": {
        "size": "3.75rem",
        "lineHeight": "1.1",
        "letterSpacing": "-0.02em",
        "fontWeight": "700"
      },
      "display-md": {
        "size": "3rem",
        "lineHeight": "1.15",
        "letterSpacing": "-0.01em",
        "fontWeight": "700"
      },
      "display-sm": {
        "size": "2.25rem",
        "lineHeight": "1.2",
        "letterSpacing": "-0.01em",
        "fontWeight": "600"
      },
      "display-xs": {
        "size": "1.875rem",
        "lineHeight": "1.3",
        "letterSpacing": "0",
        "fontWeight": "600"
      }
    },
    "lineHeight": {
      "relaxed": "1.6"
    }
  },
  "boxShadow": {
    "soft-sm": "0 2px 8px rgba(15, 23, 42, 0.08)",
    "soft-md": "0 4px 16px rgba(15, 23, 42, 0.12)",
    "soft-lg": "0 8px 24px rgba(15, 23, 42, 0.16)",
    "glow-purple": "0 0 30px rgba(13, 148, 136, 0.35)",
    "glow-pink": "0 0 30px rgba(255, 179, 217, 0.5)",
    "glow-cyan": "0 0 30px rgba(20, 184, 166, 0.45)",
    "glass": "0 8px 32px 0 rgba(15, 23, 42, 0.12)",
    "neon": "0 0 5px rgba(20, 184, 166, 0.5), 0 0 20px rgba(20, 184, 166, 0.3)"
  },
  "backgroundImage": {
    "gradient-mesh": "linear-gradient(135deg, #0f172a 0%, #0d9488 50%, #14b8a6 100%)",
    "gradient-soft": "linear-gradient(135deg, #f8fafc 0%, #f0fdfa 100%)",
    "gradient-radial": "radial-gradient(circle at 50% 0%, rgba(13, 148, 136, 0.14) 0%, rgba(15, 23, 42, 0.06) 55%, transparent 80%)"
  },
  "spacing": {
    "18": "4.5rem",
    "88": "22rem",
    "100": "25rem",
    "112": "28rem",
    "128": "32rem"
  },
  "borderRadius": {
    "default": "0.5rem"
  },
  "backdropBlur": {
    "xs": "2px"
  },
  "animations": {
    "fade-up": {
      "duration": "0.6s",
      "timing": "ease-out",
      "keyframes": {
        "0%": { "opacity": "0", "transform": "translateY(20px)" },
        "100%": { "opacity": "1", "transform": "translateY(0)" }
      }
    },
    "fade-in": {
      "duration": "0.4s",
      "timing": "ease-out",
      "keyframes": {
        "0%": { "opacity": "0" },
        "100%": { "opacity": "1" }
      }
    },
    "slide-in": {
      "duration": "0.4s",
      "timing": "ease-out",
      "keyframes": {
        "0%": { "transform": "translateX(-100%)" },
        "100%": { "transform": "translateX(0)" }
      }
    },
    "float": {
      "duration": "6s",
      "timing": "ease-in-out",
      "iteration": "infinite",
      "keyframes": {
        "0%, 100%": { "transform": "translateY(0)" },
        "50%": { "transform": "translateY(-20px)" }
      }
    },
    "bounce-slow": {
      "duration": "3s",
      "timing": "ease-in-out",
      "iteration": "infinite"
    },
    "wiggle": {
      "duration": "1s",
      "timing": "ease-in-out",
      "iteration": "infinite",
      "keyframes": {
        "0%, 100%": { "transform": "rotate(-3deg)" },
        "50%": { "transform": "rotate(3deg)" }
      }
    },
    "pulse-slow": {
      "duration": "3s",
      "timing": "cubic-bezier(0.4, 0, 0.6, 1)",
      "iteration": "infinite"
    },
    "spin-slow": {
      "duration": "8s",
      "timing": "linear",
      "iteration": "infinite"
    },
    "ping-slow": {
      "duration": "2s",
      "timing": "cubic-bezier(0, 0, 0.2, 1)",
      "iteration": "infinite"
    },
    "gradient": {
      "duration": "8s",
      "timing": "ease",
      "iteration": "infinite",
      "keyframes": {
        "0%, 100%": { "backgroundPosition": "0% 50%" },
        "50%": { "backgroundPosition": "100% 50%" }
      }
    },
    "blob": {
      "duration": "7s",
      "iteration": "infinite",
      "keyframes": {
        "0%": { "transform": "translate(0px, 0px) scale(1)" },
        "33%": { "transform": "translate(30px, -50px) scale(1.1)" },
        "66%": { "transform": "translate(-20px, 20px) scale(0.9)" },
        "100%": { "transform": "translate(0px, 0px) scale(1)" }
      }
    },
    "tilt": {
      "duration": "10s",
      "timing": "linear",
      "iteration": "infinite",
      "keyframes": {
        "0%, 50%, 100%": { "transform": "rotate(0deg)" },
        "25%": { "transform": "rotate(1deg)" },
        "75%": { "transform": "rotate(-1deg)" }
      }
    }
  }
}
